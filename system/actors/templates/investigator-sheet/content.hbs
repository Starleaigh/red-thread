</script>

{{!-- ═══════════════════════════════════════════════════════
      PAGE 7 FRONT — Notes D
════════════════════════════════════════════════════════════ --}}
<script type="text/x-handlebars-page" data-page="7" data-face="front">
  <div class="notes-page" data-notes-page="d">
    <textarea class="notes-field" data-field="system.notes_d">{{system.notes_d}}</textarea>
  </div>
</script>

</div>{{!-- .rt-content-store --}}